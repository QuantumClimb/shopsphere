generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductCategory {
  id               Int               @id @default(autoincrement())
  name             String
  masterFragrances MasterFragrance[]
  products         Product[]
}

model MasterFragrance {
  id              Int             @id @default(autoincrement())
  name            String
  brand           String?
  description     String?
  price           Float?
  volume          Float?
  concentration   String?
  gender          String?
  fragranceFamily String?
  topNotes        String?
  middleNotes     String?
  baseNotes       String?
  categoryId      Int
  imageUrl        String?
  imageData       String?
  imageMimeType   String?
  imageSize       Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  category        ProductCategory @relation(fields: [categoryId], references: [id])
  products        Product[]
}

model Product {
  id                Int              @id @default(autoincrement())
  name              String
  namePt            String?
  description       String
  descriptionPt     String?
  price             Float
  brand             String?
  volume            Float?
  concentration     String?
  gender            String?
  fragranceFamily   String?
  topNotes          String?
  middleNotes       String?
  baseNotes         String?
  stockQuantity     Int              @default(0)
  inStock           Boolean          @default(true)
  categoryId        Int
  imageUrl          String?
  imageData         String?
  imageMimeType     String?
  imageSize         Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  masterFragranceId Int?
  category          ProductCategory  @relation(fields: [categoryId], references: [id])
  masterFragrance   MasterFragrance? @relation(fields: [masterFragranceId], references: [id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  addresses Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id                   Int           @id @default(autoincrement())
  orderNumber          String        @unique
  customerId           Int?
  customerName         String
  customerEmail        String
  customerPhone        String
  deliveryAddress      Json
  deliveryInstructions String?
  orderItems           Json
  subtotal             Float
  deliveryFee          Float         @default(0)
  total                Float
  status               OrderStatus   @default(PENDING)
  paymentStatus        PaymentStatus @default(PENDING)
  paymentMethod        PaymentMethod
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  confirmedAt          DateTime?
  completedAt          DateTime?
  razorpayOrderId      String?       @unique
  razorpayPaymentId    String?       @unique
  razorpaySignature    String?
  customer             Customer?     @relation(fields: [customerId], references: [id])

  @@index([orderNumber])
  @@index([customerEmail])
  @@index([status])
  @@index([createdAt])
}

model StoreStatus {
  id            Int       @id @default(1)
  isOpen        Boolean   @default(true)
  closedMessage String?
  reopenTime    DateTime?
  updatedAt     DateTime  @updatedAt
  updatedBy     String?

  @@map("store_status")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  CASH
  BANK_TRANSFER
}
